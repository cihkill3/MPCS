@echo off
:: =====================================================================
:: Windows CMD 창에서 한글이 깨지는 것을 방지하기 위해 UTF-8 인코딩으로 설정합니다.
chcp 65001 > nul
:: =====================================================================

echo ===================================================
echo           GitHub 코드 자동 업데이트 스크립트
echo ===================================================
echo.

:: 현재 깃 상태를 간단하게 보여줍니다. (어떤 파일이 수정되었는지 확인 용도)
echo [현재 변경된 파일 목록]
git status --short
echo.

:: 1단계: 변경된 모든 파일을 추가 (git add .)
:: 폴더 내의 추가/수정/삭제된 모든 사항을 깃에 반영할 준비를 합니다.
echo [1/3] 변경된 모든 파일을 추가하는 중입니다... (git add .)
git add .
echo 완료되었습니다.
echo.

:: 2단계: 커밋 메시지 입력 및 커밋 (git commit)
:: 사용자에게 어떤 작업을 했는지 메모(커밋 메시지)를 직접 입력받습니다.
set /p commit_msg="커밋 메시지를 입력하세요 (그냥 엔터를 누르면 '자동 업데이트'로 저장됩니다): "

:: 만약 아무것도 입력하지 않고 엔터를 쳤다면, 기본 메시지를 할당합니다.
if "%commit_msg%"=="" (
    set commit_msg=자동 업데이트: 코드 변경사항 반영
)

:: 입력받은 메시지(또는 기본 메시지)를 사용해 커밋을 진행합니다.
echo [2/3] 변경 사항을 확정하는 중입니다... (git commit)
git commit -m "%commit_msg%"
echo 완료되었습니다.
echo.

:: 3단계: GitHub 서버로 업로드 (git push)
:: 기본적으로 많이 사용하는 main 브랜치로 설정합니다. 
:: 만약 사용하는 브랜치 이름이 master라면 아래 main을 master로 수정하세요.
set branch_name=main
set /p user_branch="푸시할 브랜치 이름을 입력하세요 (기본값 'main', 그대로 쓰려면 엔터): "

:: 사용자가 다른 브랜치 이름을 입력했다면 그 이름으로 덮어씁니다.
if not "%user_branch%"=="" (
    set branch_name=%user_branch%
)

echo [3/3] GitHub 서버로 업로드하는 중입니다... (git push origin %branch_name%)
git push origin %branch_name%
echo.

:: 모든 작업이 끝났음을 알리고, 사용자가 결과를 확인할 수 있도록 창을 일시 정지합니다.
echo ===================================================
echo          GitHub 업데이트 작업이 완료되었습니다!
echo ===================================================
pause